{
  "manifest_version": 3,
  "name": "Доменный светофор",
  "version": "1.0.0",
  "description": "Проверка доменов на фишинг с помощью AI. Защита от мошеннических сайтов в один клик.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://www.gmotia.tech/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
