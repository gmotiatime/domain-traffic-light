OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODELS=deepseek/deepseek-v3.2
# Optional: override OpenRouter endpoint / app identity / temperature
# OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
# OPENROUTER_REFERER=https://gmotia.tech
# OPENROUTER_APP_TITLE=Domain Traffic Light
# AI_TEMPERATURE=0.08
ADMIN_TOKEN=change_me
KV_REST_API_URL=
KV_REST_API_TOKEN=
THREAT_CACHE_PREFIX=
THREAT_CACHE_VERSION=stable
THREAT_CACHE_LEGACY_PREFIXES=threat-cache:v7,threat-cache:v6
LOCAL_THREAT_DB=true
OPENPHISH_FEED_URL=https://raw.githubusercontent.com/openphish/public_feed/refs/heads/main/feed.txt
OPENPHISH_REFRESH_MS=1800000
URLABUSE_EMAIL=your_urlabuse_email_here
URLABUSE_TOKEN=your_urlabuse_token_here
URLABUSE_ACL=ALL
URLABUSE_REFRESH_MS=300000
URLABUSE_MAX_PAGES=1
NETWORK_SIGNAL_TIMEOUT_MS=3000
AI_TIMEOUT_MS=8000
# Max duration for the SSE analyze-stream upstream request (default 60000).
# AI_STREAM_TIMEOUT_MS=60000
CORS_ORIGIN=https://your-username.github.io
PORT=8787
